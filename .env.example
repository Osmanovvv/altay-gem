# =============================================================
# Шаблон переменных окружения (скопируй в .env и заполни).
# Реальный .env НЕ коммитится. Полный список валидируется
# бэкендом на старте (шаг 0.2) — приложение не поднимется
# без обязательных ключей.
# =============================================================

# --- окружение ---
NODE_ENV=development

# --- backend ---
PORT=3000
# 5433 снаружи docker-стека: 5432 на хосте занят локальным PostgreSQL Windows
DATABASE_URL=postgresql://altai:altai@localhost:5433/altai
REDIS_URL=redis://localhost:6379

# --- strapi ---
STRAPI_URL=http://localhost:1337
# База ссылок на медиа (фото товаров), которые видит браузер.
# Локально = STRAPI_URL; на проде — https://домен (uploads отдаёт nginx)
STRAPI_PUBLIC_URL=http://localhost:1337
STRAPI_API_TOKEN=

# --- эвотор (этап 2) ---
EVOTOR_API_BASE=https://api.evotor.ru
# Юзер-токен Облака (для НАШИХ вызовов api.evotor.ru). Штатно приходит сам
# при установке приложения (POST /user/token); env — ручной запасной вариант.
EVOTOR_CLOUD_TOKEN=
# Токен вкладки «Интеграция» кабинета: Эвотор шлёт его в Authorization
# своих push-уведомлений НАМ. Не путать с CLOUD-токеном!
EVOTOR_WEBHOOK_TOKEN=
EVOTOR_STORE_ID_LENINGRADSKAYA=
EVOTOR_STORE_ID_TITOVA=

# --- оплата ЮKassa / фискализация 54-ФЗ (этап 3) ---
# СНАЧАЛА тестовый магазин (test_-ключ, деньги не двигаются), потом боевой.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# База API (дефолт https://api.yookassa.ru/v3 — тест/бой различаются ключами)
# YOOKASSA_API_BASE=
# База return_url (страница «спасибо за заказ»)
PUBLIC_SITE_URL=https://ecomarket-altai.ru
# Чеки («Чеки от ЮKassa»): без true платежи будут отклоняться —
# на магазине включена фискализация, платёж без чека невозможен.
YOOKASSA_RECEIPT_ENABLED=true
YOOKASSA_VAT_CODE=1                # 1 = «Без НДС» (УСН); боевое значение подтверждает бухгалтер
YOOKASSA_PAYMENT_MODE=full_payment
YOOKASSA_RECEIPT_MEASURE=piece
YOOKASSA_RECEIPT_TIMEZONE=6        # Новосибирск (UTC+7)
# Строгая проверка IP вебхука (после проверки XFF на проде)
# YOOKASSA_WEBHOOK_VERIFY_IP=true
# Автоотмена неоплаченных, минут (дефолт 30)
# ORDER_PAYMENT_TTL_MINUTES=30

# --- админка заказов (этап 3) ---
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- уведомления (этап 3) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- MAX mini app (этап 4) ---
MAX_BOT_TOKEN=

# --- TLS/доверие (шаг 0.9) ---
# NODE_EXTRA_CA_CERTS=./infra/certs/russian_trusted_root_ca.cer
