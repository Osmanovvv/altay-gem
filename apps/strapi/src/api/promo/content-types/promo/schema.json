{
  "kind": "collectionType",
  "collectionName": "promos",
  "info": {
    "singularName": "promo",
    "pluralName": "promos",
    "displayName": "Акция",
    "description": "Страницы /promo и /promo/{slug} (ТЗ 6.8, 7.2)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "detailText": {
      "type": "richtext"
    },
    "conditions": {
      "type": "component",
      "repeatable": true,
      "component": "promo.condition"
    },
    "promocode": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::promocode.promocode"
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    },
    "validFrom": {
      "type": "datetime"
    },
    "validTo": {
      "type": "datetime"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  }
}
