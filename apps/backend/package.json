{
  "name": "@altai/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Бэкенд «Жемчужина Алтая»: каталог, остатки, заказы, промокоды, интеграции (NestJS + PostgreSQL)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint src",
    "test": "bun test src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.4.1",
    "pg": "^8.22.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.8",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}